# FARIS Production Environment
# ==============================================================================
# Use this file as a template for production deployment

# Application Settings
APP_NAME=FARIS
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=WARNING

# API Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# CORS Settings - Update with your frontend domain
CORS_ORIGINS=["https://your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Database Settings (PostgreSQL recommended for production)
DATABASE_URL=postgresql+asyncpg://faris:your_secure_password@localhost:5432/faris

# Vector Database Settings
CHROMA_PERSIST_DIRECTORY=/app/chroma_db
CHROMA_COLLECTION_NAME=faris_failures

# LLM Provider Configuration
# Use "ollama" for local GPU deployment
LLM_PROVIDER=ollama

# Ollama Settings (for production with GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=4096

# Gemini Settings (keep for fallback)
# GEMINI_API_KEY=your_api_key
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_TIMEOUT=120

# Embeddings Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cuda

# Analysis Settings
FAILURE_CONFIDENCE_THRESHOLD=0.5
WEIGHT_HALLUCINATION=0.35
WEIGHT_LOGICAL_INCONSISTENCY=0.25
WEIGHT_MISSING_ASSUMPTIONS=0.20
WEIGHT_OVERCONFIDENCE=0.10
WEIGHT_SCOPE_VIOLATION=0.05
WEIGHT_UNDERSPECIFICATION=0.05

# Domain risk multipliers
DOMAIN_MULTIPLIER_GENERAL=1.0
DOMAIN_MULTIPLIER_FINANCE=1.5
DOMAIN_MULTIPLIER_MEDICAL=2.0
DOMAIN_MULTIPLIER_LEGAL=1.8
DOMAIN_MULTIPLIER_CODE=1.3

# Rate Limiting (recommended for production)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600
